<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.betterblocks">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BetterBlocks">

        <!-- Main launcher activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Game activity (launched from MainActivity) -->
        <activity
            android:name=".GameActivity"
            android:exported="false" />

        <!-- 3. Highscores Activity -->
        <activity
            android:name=".HighscoresActivity"
            android:exported="false" />

        <!-- 4. Shop Activity -->
        <activity
            android:name=".ShopActivity"
            android:exported="false" />

        <!-- 5. Settings Activity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- 6. Developer Activity (Use this to fix the crash) -->
        <activity
            android:name=".DeveloperActivity"
            android:exported="false"
            android:label="Developer Menu"/>

    </application>
</manifest>