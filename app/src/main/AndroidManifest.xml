<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:versionCode="14"
    android:versionName="1.0.14">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Runtime permission required on Android 13+; request from an Activity when the user enables notifications in UI -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:name=".BetterBlocksApp"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BetterBlocks">

        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <!-- Main launcher activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Game activity (launched from MainActivity) -->
        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- 4. Shop Activity -->
        <activity
            android:name=".ShopActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".HighScoreActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Stats Activity -->
        <activity
            android:name=".StatsActivity"
            android:exported="false"
            android:label="Stats"
            android:screenOrientation="portrait" />

        <!-- 6. Developer Activity (Use this to fix the crash) -->
        <activity
            android:name=".DeveloperActivity"
            android:exported="false"
            android:label="Developer Menu"
            android:screenOrientation="portrait" />

        <!-- Notification receiver: receives AlarmManager broadcasts even when app is not running -->
        <receiver
            android:name="com.betterblocks.notifications.NotificationReceiver"
            android:exported="true" />

        <!-- FCM messaging service to receive topic broadcasts for highscores -->
        <service
            android:name=".HighscoreFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- TODO: If you want reminders to survive device reboot, add a BootReceiver and the
             RECEIVE_BOOT_COMPLETED permission here. -->

    </application>
</manifest>